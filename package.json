{
  "name": "pretty-parcel",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "0.2.3",
    "@expo-google-fonts/poppins": "0.2.3",
    "@expo/vector-icons": "14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "buffer": "^6.0.3",
    "expo": "57.0.3",
    "expo-constants": "57.0.3",
    "expo-font": "57.0.0",
    "expo-linking": "57.0.2",
    "expo-router": "57.0.4",
    "expo-splash-screen": "57.0.2",
    "expo-status-bar": "57.0.0",
    "expo-symbols": "57.0.0",
    "expo-web-browser": "57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.11.1",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/react": "19.2.2",
    "typescript": "6.0.3",
    "wrangler": "^4.107.1"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "typecheck": "tsc --noEmit && tsc -p server",
    "api:dev": "wrangler dev -c server/wrangler.dev.toml --persist-to .wrangler/state",
    "db:migrate": "wrangler d1 execute pretty-parcel-db --remote --file server/migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute pretty-parcel-db --remote --file server/seed.sql",
    "db:migrate:local": "wrangler d1 execute pretty-parcel-db -c server/wrangler.dev.toml --persist-to .wrangler/state --local --file server/migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute pretty-parcel-db -c server/wrangler.dev.toml --persist-to .wrangler/state --local --file server/seed.sql",
    "db:migrate:0002": "wrangler d1 execute pretty-parcel-db --remote --file server/migrations/0002_product_is_active.sql",
    "db:migrate:0002:local": "wrangler d1 execute pretty-parcel-db -c server/wrangler.dev.toml --persist-to .wrangler/state --local --file server/migrations/0002_product_is_active.sql",
    "db:migrate:0003": "wrangler d1 execute pretty-parcel-db --remote --file server/migrations/0003_product_stock.sql",
    "db:migrate:0003:local": "wrangler d1 execute pretty-parcel-db -c server/wrangler.dev.toml --persist-to .wrangler/state --local --file server/migrations/0003_product_stock.sql",
    "deploy": "expo export --platform web && wrangler deploy"
  },
  "private": true
}
